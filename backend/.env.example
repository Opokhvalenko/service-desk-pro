# ── App ──
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:4200

# ── Database ──
# Cloud (Neon):
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/db?sslmode=require
# Local (docker-compose):
# DATABASE_URL=postgresql://sdp:sdp_dev_password@localhost:5432/service_desk_pro
# DIRECT_URL=postgresql://sdp:sdp_dev_password@localhost:5432/service_desk_pro

# ── Redis ──
# Cloud (Upstash):
REDIS_URL=rediss://default:token@host:6379
# Local (docker-compose):
# REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Cookies ──
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=service_desk_attachments

# ── Sentry ──
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── OpenTelemetry / Honeycomb ──
OTEL_SERVICE_NAME=service-desk-pro-backend
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.eu1.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-honeycomb-api-key

# ── Email (Mailhog locally / Resend on prod) ──
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@service-desk-pro.com

# ── Throttling ──
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Logging ──
LOG_LEVEL=debug
